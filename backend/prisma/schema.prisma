generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int        @id @default(autoincrement())
  email             String
  password          String?
  nom               String
  prenoms           String
  telephone         String?
  nomEntreprise     String?
  pieceIdentitePath String?
  role              Role
  googleId          String?
  resetToken        String?    @unique
  resetTokenExpires DateTime?
  createdAt         DateTime   @default(now())
  deletedAt         DateTime?
  campagnes         Campagne[]
  portefeuille      Portefeuille?

  @@unique([email, role])
  @@unique([googleId, role])
}

enum Role {
  annonceur
  diffuseur
}

model Pays {
  id        Int        @id @default(autoincrement())
  code      String     @unique
  label     String
  localites Localite[]
  campagnes Campagne[]
}

model Localite {
  id        Int                @id @default(autoincrement())
  label     String
  pays      Pays               @relation(fields: [paysId], references: [id])
  paysId    Int
  campagnes CampagneLocalite[]
}

model Profession {
  id        Int                  @id @default(autoincrement())
  label     String
  campagnes CampagneProfession[]
}

model CategorieCiblage {
  id        Int                        @id @default(autoincrement())
  label     String
  campagnes CampagneCategorieCiblage[]
}

model TypeMedia {
  id        Int        @id @default(autoincrement())
  code      String     @unique
  label     String
  campagnes Campagne[]
}

model CategorieCampagne {
  id        Int        @id @default(autoincrement())
  code      String     @unique
  label     String
  campagnes Campagne[]
}

model Campagne {
  id                Int                        @id @default(autoincrement())
  nom               String
  description       String?                    @db.Text
  dateDebut         DateTime
  dateFin           DateTime
  heureDiffusion    String
  budget            Float
  montantParVue     Float                      @default(2.5)
  ageMin            Int                        @default(18)
  ageMax            Int                        @default(99)
  legende           String?                    @db.Text
  statut            StatutCampagne             @default(en_attente)
  annonceur         User                       @relation(fields: [annonceurId], references: [id])
  annonceurId       Int
  pays              Pays?                      @relation(fields: [paysId], references: [id])
  paysId            Int?
  typeMedia         TypeMedia?                 @relation(fields: [typeMediaId], references: [id])
  typeMediaId       Int?
  categorie         CategorieCampagne?         @relation(fields: [categorieId], references: [id])
  categorieId       Int?
  localites         CampagneLocalite[]
  professions       CampagneProfession[]
  categoriesCiblage CampagneCategorieCiblage[]
  medias            CampagneMedia[]
  transactions      Transaction[]
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  deletedAt         DateTime?
}

enum StatutCampagne {
  en_attente
  actif
  cloture
  rejete
}

model CampagneLocalite {
  campagne   Campagne @relation(fields: [campagneId], references: [id])
  campagneId Int
  localite   Localite @relation(fields: [localiteId], references: [id])
  localiteId Int

  @@id([campagneId, localiteId])
}

model CampagneProfession {
  campagne     Campagne   @relation(fields: [campagneId], references: [id])
  campagneId   Int
  profession   Profession @relation(fields: [professionId], references: [id])
  professionId Int

  @@id([campagneId, professionId])
}

model CampagneCategorieCiblage {
  campagne           Campagne         @relation(fields: [campagneId], references: [id])
  campagneId         Int
  categorieCiblage   CategorieCiblage @relation(fields: [categorieCiblageId], references: [id])
  categorieCiblageId Int

  @@id([campagneId, categorieCiblageId])
}

model CampagneMedia {
  id         Int      @id @default(autoincrement())
  campagne   Campagne @relation(fields: [campagneId], references: [id])
  campagneId Int
  path       String
  mimetype   String
  createdAt  DateTime @default(now())
}

model Portefeuille {
  id            Int          @id @default(autoincrement())
  userId        Int          @unique
  user          User         @relation(fields: [userId], references: [id])
  solde         Float        @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  transactions  Transaction[]
}

model Transaction {
  id                Int          @id @default(autoincrement())
  portefeuille      Portefeuille @relation(fields: [portefeuilleId], references: [id])
  portefeuilleId    Int
  type              String       // depot, depense, remboursement, retrait
  montant           Float
  fedapayId         Int?                   // ID numérique FedaPay
  reference         String?      @unique    // référence FedaPay
  statut            String       @default("en_attente")  // en_attente, reussi, echoue
  fedapayStatus     String?                 // statut exact FedaPay: pending, approved, transferred, etc.
  description       String?
  modePaiement      String?      // mobile_money, card, etc.
  campagneId        Int?         // ID de la campagne si décaissement
  campagne          Campagne?    @relation(fields: [campagneId], references: [id])
  createdAt         DateTime     @default(now())
}
